{
  "name": "hotfeed-server",
  "version": "1.0.0",
  "description": "HotFeed backend — Express + PostgreSQL + Redis + Socket.io",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "ts-node database/seed.ts",
    "db:schema": "psql $DATABASE_URL -f database/schema.sql"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "pg": "^8.11.3",
    "ioredis": "^5.3.2",
    "zod": "^3.22.4",
    "dotenv": "^16.3.1",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.1.5",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.2",
    "@types/express": "^4.17.21",
    "@types/pg": "^8.10.9",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.7",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "nodemon": "^3.0.2"
  }
}
